<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="rfdetect.DashboardController"
            style="-fx-background-color: #1a1a2e;">

    <top>
        <HBox spacing="20" alignment="CENTER_LEFT"
              style="-fx-background-color: #16213e; -fx-padding: 15 20 15 20;">
            <Label text="RF JAMMING DETECTION SYSTEM"
                   style="-fx-text-fill: #00d9ff; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="apiStatusLabel" text="API: Checking..."
                   style="-fx-text-fill: #ffa500; -fx-font-size: 13px;"/>
            <Label fx:id="timestampLabel" text="--:--:--"
                   style="-fx-text-fill: white; -fx-font-size: 13px;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="10" style="-fx-padding: 15;">
            <HBox spacing="10">
                <LineChart fx:id="rssiChart" HBox.hgrow="ALWAYS" prefHeight="280">
                    <xAxis><NumberAxis label="Time (s)"/></xAxis>
                    <yAxis><NumberAxis label="RSSI (dBm)"/></yAxis>
                </LineChart>
                <LineChart fx:id="snrChart" HBox.hgrow="ALWAYS" prefHeight="280">
                    <xAxis><NumberAxis label="Time (s)"/></xAxis>
                    <yAxis><NumberAxis label="SNR (dB)"/></yAxis>
                </LineChart>
            </HBox>
            <HBox spacing="10">
                <LineChart fx:id="pdrChart" HBox.hgrow="ALWAYS" prefHeight="280">
                    <xAxis><NumberAxis label="Time (s)"/></xAxis>
                    <yAxis><NumberAxis label="PDR (0-1)"/></yAxis>
                </LineChart>

                <VBox fx:id="alertPanel" prefWidth="350" spacing="15"
                      style="-fx-background-color: #0f3460; -fx-padding: 20; -fx-background-radius: 5;">
                    <Label text="JAMMING ALERT"
                           style="-fx-text-fill: #00d9ff; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Region fx:id="alertIndicator" prefHeight="80"
                            style="-fx-background-color: #4caf50; -fx-background-radius: 5;"/>
                    <Label fx:id="statusLabel" text="NORMAL"
                           style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                    <Label fx:id="confidenceLabel" text="Confidence: --%"
                           style="-fx-text-fill: #b0bec5; -fx-font-size: 14px;"/>
                    <Separator/>
                    <Label text="Probabilities:"
                           style="-fx-text-fill: #b0bec5; -fx-font-size: 13px;"/>
                    <Label fx:id="probNormalLabel" text="Normal: --"
                           style="-fx-text-fill: #4caf50; -fx-font-size: 13px;"/>
                    <Label fx:id="probWeakLabel" text="Weak Jam: --"
                           style="-fx-text-fill: #ffa500; -fx-font-size: 13px;"/>
                    <Label fx:id="probStrongLabel" text="Strong Jam: --"
                           style="-fx-text-fill: #f44336; -fx-font-size: 13px;"/>
                    <Separator/>
                    <Button fx:id="startBtn" text="Start Live Detection" prefWidth="280"
                            style="-fx-background-color: #00d9ff; -fx-text-fill: black; -fx-font-weight: bold;"/>
                    <Button fx:id="stopBtn" text="Stop" prefWidth="280" disable="true"
                            style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
                </VBox>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="20" alignment="CENTER_LEFT"
              style="-fx-background-color: #16213e; -fx-padding: 10 20 10 20;">
            <Label fx:id="footerLabel" text="Ready. Click 'Start Live Detection' to begin."
                   style="-fx-text-fill: #b0bec5; -fx-font-size: 12px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="inferenceLabel" text="Inference: -- ms"
                   style="-fx-text-fill: #00d9ff; -fx-font-size: 12px;"/>
        </HBox>
    </bottom>
</BorderPane>
